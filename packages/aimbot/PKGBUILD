# Maintainer: Franklin <jahdy1o3@gmail.com>
pkgname=aimbot
pkgver=1.0.8
pkgrel=1
pkgdesc="Color-tracking aimbot for Linux/X11 — i3 floating window aware"
arch=('x86_64')
url="https://github.com/Frank1o3/Aimbot"
license=('MIT')
depends=(
    'opencv'
    'libx11'
    'libxext'
)
makedepends=(
    'cmake'
    'ninja'
)
optdepends=(
    'xdotool: optional window debugging'
)
provides=('aimbot')
conflicts=()

source=(
    "aimbot-${pkgver}.tar.gz::https://github.com/Frank1o3/Aimbot/archive/refs/tags/v${pkgver}.tar.gz"
)
sha256sums=('SKIP')

build() {
    cd "Aimbot-${pkgver}"
    cmake -S . -B build \
        -GNinja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr
    cmake --build build --parallel
}

package() {
    cd "Aimbot-${pkgver}"
    DESTDIR="${pkgdir}" cmake --install build

    # Udev rule so users in the 'input' group can use /dev/uinput without sudo
    install -dm755 "${pkgdir}/usr/lib/udev/rules.d"
    echo 'KERNEL=="uinput", MODE="0660", GROUP="input"' \
        > "${pkgdir}/usr/lib/udev/rules.d/99-uinput.rules"
}

post_install() {
    echo "==> Run the following to enable uinput and keyboard/mouse input access:"
    echo "      sudo modprobe uinput"
    echo "      sudo udevadm control --reload && sudo udevadm trigger"
    echo "      sudo usermod -aG input \$USER"
    echo "    Then re-login for group membership to take effect."
}