source=("modforge_cli-${pkgver}-py3-none-any.whl::https://github.com/Frank1o3/ModForge-CLI/releases/download/v${pkgver}/modforge_cli-${pkgver}-py3-none-any.whl")
sha256sums=('SKIP')

package() {
    pip install \
        --isolated \
        --root="${pkgdir}" \
        --ignore-installed \
        --prefix=/usr \
        --no-deps \
        "${srcdir}/modforge_cli-${pkgver}-py3-none-any.whl"
}